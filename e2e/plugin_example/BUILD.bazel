# Tests
# =============================================================================

build_test(
    name = "plugin_build_test",
    targets = [
        ":plugin_app",
        "//greeting_plugin",
    ],
)

build_test(
    name = "macos_bundle_build_test",
    target_compatible_with = ["@platforms//os:macos"],
    targets = [":plugin_macos"],
)

build_test(
    name = "ios_bundle_build_test",
    target_compatible_with = ["@platforms//os:macos"],
    targets = [":plugin_ios"],
)

build_test(
    name = "linux_bundle_build_test",
    target_compatible_with = ["@platforms//os:linux"],
    targets = [":plugin_linux"],
)

build_test(
    name = "windows_bundle_build_test",
    target_compatible_with = ["@platforms//os:windows"],
    targets = [":plugin_windows"],
)

build_test(
    name = "android_bundle_build_test",
    tags = ["android"],
    targets = [":plugin_android"],
)

build_test(
    name = "web_build_test",
    targets = [":plugin_web"],
)

# Runtime verifier for the macOS bundle. Launches the .app, captures stdout,
# and asserts the four plugin-result strings appear. Tagged "manual" +
# "exclusive" because it requires a GUI session and exclusive control of the
# Dock; run explicitly per docs/TESTING.md § Plugin verification matrix.
dart_test(
    name = "verify_macos_app_test",
    data = [":plugin_macos"],
    main = "test/verify_macos_app_test.dart",
    tags = [
        "exclusive",
        "manual",
    ],
    target_compatible_with = ["@platforms//os:macos"],
)
