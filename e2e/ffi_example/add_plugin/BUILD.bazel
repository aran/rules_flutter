load("@rules_flutter//flutter:defs.bzl", "flutter_plugin")
load("@rules_flutter//flutter:native_assets.bzl", "flutter_native_asset")

# Demonstrate the Native Assets pipeline end to end: the shared library is
# declared as a Dart Native Asset on every platform, and the Dart side binds
# with a bare `@Native(symbol: ...)` — no asset id, no paths, no Platform
# switch. The id below is the default the Dart VM derives for annotations in
# `lib/add_plugin.dart` (the library's URI), which is exactly how hook-built
# pub packages behave, so the same Dart source works under `flutter run`.
#
# One target per OS: `flutter_native_asset` declares "this file is the
# asset on <os>", and the bundle filename follows each platform's
# convention. On iOS the dylib is additionally wrapped in a signed
# `add.framework` (loose embedded dylibs are forbidden there); the manifest
# records `add.framework/add`. Runtime binds are proven by
# //:verify_ios_simulator_test and //:verify_macos_runtime_test.

_ADD_ASSET_ID = "package:add_plugin/add_plugin.dart"

flutter_native_asset(
    name = "add_native_asset_ios",
    asset_id = _ADD_ASSET_ID,
    bundle_filename = "add.dylib",
    library = "//:add",
    link_mode = "dynamic_loading_bundle",
    target_os = "ios",
)

flutter_native_asset(
    name = "add_native_asset_macos",
    asset_id = _ADD_ASSET_ID,
    bundle_filename = "libadd.dylib",
    library = "//:add",
    link_mode = "dynamic_loading_bundle",
    target_os = "macos",
)

flutter_native_asset(
    name = "add_native_asset_linux",
    asset_id = _ADD_ASSET_ID,
    bundle_filename = "libadd.so",
    library = "//:add",
    link_mode = "dynamic_loading_bundle",
    target_os = "linux",
)

flutter_native_asset(
    name = "add_native_asset_windows",
    asset_id = _ADD_ASSET_ID,
    bundle_filename = "add.dll",
    library = "//:add",
    link_mode = "dynamic_loading_bundle",
    target_os = "windows",
)

flutter_plugin(
    name = "add_plugin",
    srcs = ["lib/add_plugin.dart"],
    native_assets = select({
        "@platforms//os:ios": [":add_native_asset_ios"],
        "@platforms//os:linux": [":add_native_asset_linux"],
        "@platforms//os:macos": [":add_native_asset_macos"],
        "@platforms//os:windows": [":add_native_asset_windows"],
        "//conditions:default": [],
    }),
    platforms = [
        "ios",
        "macos",
        "linux",
        "windows",
    ],
    visibility = ["//visibility:public"],
)
